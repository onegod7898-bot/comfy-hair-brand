# Get your form ID from https://formspree.io (e.g. from the form endpoint: https://formspree.io/f/xxxxxxxx)
# You'll receive an email when customers add to cart or place an order.
VITE_FORMSPREE_FORM_ID=your_formspree_form_id_here

# Admin orders page: set a secret password. Only you use this to view /admin (active, pending, shipped, cancelled orders).
# Set ADMIN_SECRET in Vercel Environment Variables (same value as your chosen password).
# ADMIN_SECRET=your_secret_password

# Orders are stored in Vercel Blob. Add the Vercel Blob store in your project; Vercel will set BLOB_READ_WRITE_TOKEN.
